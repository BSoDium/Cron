<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools">

    <!-- Calendar reading -->
    <uses-permission android:name="android.permission.READ_CALENDAR" />

    <!-- Exact alarms (setAlarmClock for the wake alarm, setExactAndAllowWhileIdle for the evening
         trigger). USE_EXACT_ALARM covers alarm-clock apps, exempting us from the SCHEDULE_EXACT_ALARM
         user grant on 12+. -->
    <uses-permission
        android:name="android.permission.USE_EXACT_ALARM"
        tools:ignore="ExactAlarmPolicy" />

    <!-- Re-schedule alarms after device reboot -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />

    <!-- Notification permission (Android 13+) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <!-- Full-screen alarm overlay on lock screen -->
    <uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />

    <!-- Keep CPU alive briefly while processing alarm -->
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Vibrate for alarm -->
    <uses-permission android:name="android.permission.VIBRATE" />

    <!-- Network access for Google Routes API (travel time estimation) -->
    <uses-permission android:name="android.permission.INTERNET" />

    <!-- Coarse location for travel time origin (city-block accuracy is sufficient) -->
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <!-- Background location: the once-nightly plan refreshes the origin while the app is closed.
         A location-typed FGS started from the background can only access location with this grant. -->
    <uses-permission android:name="android.permission.ACCESS_BACKGROUND_LOCATION" />

    <!-- Activity Recognition (transition API for out-of-bed detection) -->
    <uses-permission android:name="android.permission.ACTIVITY_RECOGNITION" />

    <!-- Foreground service for hosting dynamic sensor receivers overnight -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_LOCATION" />

    <!-- Battery optimization exemption for reliable overnight tracking -->
    <uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />

    <!-- Health Connect: sleep session records -->
    <uses-permission android:name="android.permission.health.READ_SLEEP" />

    <!-- Health Connect provider visibility (Android 11+) -->
    <queries>
        <package android:name="com.google.android.apps.healthdata" />
    </queries>

    <application
        android:name=".CronApplication"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:enableOnBackInvokedCallback="true"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Cron">

        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:theme="@style/Theme.Cron.Starting">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
            <!-- Health Connect opens this for the permission rationale on Android 13 and below. -->
            <intent-filter>
                <action android:name="androidx.health.connect.action.SHOW_PERMISSIONS_RATIONALE" />
            </intent-filter>
        </activity>

        <!-- Health Connect rationale entry point on Android 14+ (VIEW_PERMISSION_USAGE). -->
        <activity-alias
            android:name="ViewPermissionUsageActivity"
            android:exported="true"
            android:permission="android.permission.START_VIEW_PERMISSION_USAGE"
            android:targetActivity=".MainActivity">
            <intent-filter>
                <action android:name="android.intent.action.VIEW_PERMISSION_USAGE" />
                <category android:name="android.intent.category.HEALTH_PERMISSIONS" />
            </intent-filter>
        </activity-alias>

        <!-- Full-screen lock-screen alarm UI -->
        <activity
            android:name=".ui.screens.alarm.AlarmActivity"
            android:showWhenLocked="true"
            android:turnScreenOn="true"
            android:excludeFromRecents="true"
            android:exported="false" />

        <!-- Alarm notification receiver -->
        <receiver
            android:name=".receiver.AlarmReceiver"
            android:exported="false" />

        <!-- Re-schedule alarms on boot -->
        <receiver
            android:name=".receiver.BootReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.BOOT_COMPLETED" />
            </intent-filter>
        </receiver>

        <!-- Re-sync when calendar changes -->
        <receiver
            android:name=".receiver.CalendarChangeReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.PROVIDER_CHANGED" />
                <data
                    android:host="com.android.calendar"
                    android:scheme="content" />
            </intent-filter>
        </receiver>

        <!-- Re-arm evening trigger when system timezone changes (travel DST) -->
        <receiver
            android:name=".receiver.TimeZoneChangedReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.TIMEZONE_CHANGED" />
            </intent-filter>
        </receiver>

        <!-- Daily evening trigger that starts a sleep session -->
        <receiver
            android:name=".receiver.EveningPlanReceiver"
            android:exported="false" />

        <!-- Long-running foreground service hosting overnight sensor monitors -->
        <service
            android:name=".service.SleepSessionService"
            android:exported="false"
            android:foregroundServiceType="specialUse|location">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="overnight sleep stage monitoring for adaptive alarm" />
        </service>

    </application>

</manifest>
